# MongoDB
# Local Docker default:
MONGODB_URI=mongodb://mongodb:27017
# Example Atlas URI:
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/rag_chatbot?retryWrites=true&w=majority
MONGODB_DB_NAME=rag_chatbot

# Chroma
CHROMA_PERSIST_DIR=chroma
CHROMA_COLLECTION_NAME=rag_chunks

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Storage
UPLOAD_DIR=storage/raw
MARKDOWN_DIR=storage/markdown

# CORS
CORS_ORIGINS=http://localhost:3000
